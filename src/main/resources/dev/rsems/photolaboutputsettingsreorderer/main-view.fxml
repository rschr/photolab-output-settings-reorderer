<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane xmlns:fx="http://javafx.com/fxml"
            fx:controller="dev.rsems.photolaboutputsettingsreorderer.MainController"
            prefWidth="620" prefHeight="520">

    <top>
        <ToolBar>
            <Button text="Open…" onAction="#onOpen"/>
            <Label fx:id="fileLabel" text="(no file open)" style="-fx-padding: 0 0 0 8;"/>
        </ToolBar>
    </top>

    <center>
        <HBox spacing="8">
            <BorderPane.margin>
                <Insets top="8" right="8" bottom="4" left="8"/>
            </BorderPane.margin>
            <ListView fx:id="listView" HBox.hgrow="ALWAYS"/>
            <VBox spacing="6" alignment="TOP_CENTER">
                <Button fx:id="moveUpButton"   text="↑ Up"     onAction="#onMoveUp"   maxWidth="Infinity"/>
                <Button fx:id="moveDownButton" text="↓ Down"   onAction="#onMoveDown" maxWidth="Infinity"/>
                <Button fx:id="removeButton"   text="✕ Remove" onAction="#onRemove"   maxWidth="Infinity"/>
            </VBox>
        </HBox>
    </center>

    <bottom>
        <VBox>
            <HBox spacing="8" alignment="CENTER_LEFT">
                <VBox.margin>
                    <Insets top="4" right="8" bottom="4" left="8"/>
                </VBox.margin>
                <Button fx:id="restoreButton" text="Restore Backup…" onAction="#onRestoreBackup"/>
                <Region HBox.hgrow="ALWAYS"/>
                <Button fx:id="revertButton" text="Revert" onAction="#onRevert"/>
                <Button fx:id="saveButton" text="Save Changes" onAction="#onSave"
                        style="-fx-font-weight: bold;"/>
            </HBox>
            <Label fx:id="statusLabel" text=""
                   style="-fx-padding: 2 8 4 8; -fx-text-fill: #555555; -fx-font-size: 11;"/>
        </VBox>
    </bottom>

</BorderPane>
